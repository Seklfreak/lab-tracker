{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "assignees": ["Seklfreak"],
  "packageRules": [
    {
      "description": "Auto-merge non-major updates once the test workflow passes.",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Major updates: open a PR but require manual review/merge.",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
