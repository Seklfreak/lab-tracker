# Copy to .env and fill in. The backend loads .env automatically (see backend/internal/config).

# Postgres
DATABASE_URL=postgres://labtracker:labtracker@localhost:5432/labtracker?sslmode=disable

# Anthropic (used for PDF extraction)
ANTHROPIC_API_KEY=sk-ant-...

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lab-results
MINIO_USE_SSL=false

# Server
PORT=8080
# Comma-separated list of allowed CORS origins for the SPA dev server
CORS_ORIGINS=http://localhost:5173

# Auth (OIDC). For local dev, disable it:
AUTH_DISABLED=true
# In production, leave AUTH_DISABLED unset and configure these (your OIDC provider):
# OIDC_ISSUER=https://auth.example.com/application/o/lab-tracker/
# OIDC_CLIENT_ID=lab-tracker

# MCP connector identity (backend/cmd/mcp). The MCP server derives the caller
# per-request from the Cloudflare Access identity JWT (Cf-Access-Jwt-Assertion),
# which Access injects after the user logs in via the connector OAuth flow. Set
# the team domain (issuer) to enable it; the email in the token is mapped to a
# lab-tracker user and every tool is scoped to that user's owned/shared profiles.
# Unset = exposes ALL profiles (local dev). CF_ACCESS_AUD pins the Access
# application's audience tag (recommended); unset accepts any of the team's apps.
# CF_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
# CF_ACCESS_AUD=
