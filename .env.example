# Copy to .env and fill in. The backend loads .env automatically (see backend/internal/config).

# Postgres
DATABASE_URL=postgres://labtracker:labtracker@localhost:5432/labtracker?sslmode=disable

# Anthropic (used for PDF extraction)
ANTHROPIC_API_KEY=sk-ant-...

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lab-results
MINIO_USE_SSL=false

# Server
PORT=8080
# Comma-separated list of allowed CORS origins for the SPA dev server
CORS_ORIGINS=http://localhost:5173

# Auth (OIDC). For local dev, disable it:
AUTH_DISABLED=true
# In production, leave AUTH_DISABLED unset and configure these (your OIDC provider):
# OIDC_ISSUER=https://auth.example.com/application/o/lab-tracker/
# OIDC_CLIENT_ID=lab-tracker

# Multi-user: set ADMIN_OIDC_SUB once when first rolling out per-user isolation
# onto a DB with pre-existing profiles. Any owner-less profile is migrated to
# this user (the OIDC `sub` of your admin account) on startup. Safe to leave set.
# ADMIN_OIDC_SUB=

# MCP connector identity (backend/cmd/mcp). The MCP server is DB-direct and
# carries no per-request identity, so scope it to one user: set their OIDC `sub`
# and the connector only sees that user's owned/shared profiles. The user must
# have signed into the web app at least once. Unset = exposes ALL profiles.
# MCP_USER_SUB=
