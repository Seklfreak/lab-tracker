<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Lab Tracker</string>
	<key>CFBundleName</key>
	<string>LabTracker</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<!-- Export compliance: the app only uses iOS's built-in encryption (HTTPS via
	     URLSession, Keychain, CryptoKit for PKCE) — exempt. Declaring it here
	     auto-clears the per-build "Missing Compliance" prompt in App Store Connect. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- iPad must support all four orientations (incl. upside-down) for
	     multitasking, or App Store validation rejects the build. -->
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>NSFaceIDUsageDescription</key>
	<string>Unlock Lab Tracker with Face ID.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Import your weight and height from Apple Health to track them alongside your lab results.</string>
	<!-- Dev: allow http to localhost (the dev backend). Prod uses https. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- OIDC redirect for the Authorization Code + PKCE flow. Reverse-DNS scheme
	     (matches the bundle id) so another app can't claim it. Full redirect URI:
	     dev.winktech.labtracker://auth/callback -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>dev.winktech.labtracker.auth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>dev.winktech.labtracker</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
